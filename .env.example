# Получите токен у @BotFather
BOT_TOKEN=1234567890:replace_with_your_telegram_bot_token

# Необязательно: путь к постоянной истории сообщений
HISTORY_DB_PATH=./data/bot-history.sqlite

# Необязательно: полноценные AI-видео под сферу каждого сайта.
# Без ключа презентация использует встроенные реалистичные GIF.
OPENAI_API_KEY=
OPENAI_VIDEO_MODEL=sora-2
OPENAI_VIDEO_SECONDS=4
OPENAI_VIDEO_SIZE=720x1280
# 1 — использовать первое продуктовое фото сайта как первый кадр.
# Фото автоматически приводится к размеру ролика; при отклонении API запрос повторяется без него.
OPENAI_VIDEO_USE_PRODUCT_REFERENCE=0
# Максимальное ожидание одной генерации, миллисекунды (2–30 минут).
OPENAI_VIDEO_TIMEOUT_MS=720000
# Необязательно: собственный ffmpeg; по умолчанию используется пакетный бинарник.
FFMPEG_PATH=
